PORT=4000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_EXPIRES_IN=15m

DB_HOST=localhost
DB_PORT=3306
DB_NAME=parent_school_platform
DB_USER=root
DB_PASSWORD=
DB_SYNC=true

AI_SERVICE_URL=http://localhost:8001
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
SCHOOL_NAME=SchoolConnect AI

# Set to true only if you want public self-registration (default: admin creates accounts)
PUBLIC_REGISTRATION_ENABLED=false

# Gmail SMTP (use an App Password — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="SchoolConnect AI <your.email@gmail.com>"

PASSWORD_RESET_OTP_MINUTES=10
